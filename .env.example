# OpenClaw - Shipcat Configuration
# Copy this file to .env and fill in your values

# === REQUIRED ===

# Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# RevenueCat API Secret Key v2 (get from app.revenuecat.com → API Keys)
REVENUECAT_API_KEY=sk_your-key-here

# === CHANNELS (configure as needed) ===

# X (Twitter) API Keys (get from developer.x.com)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Discord Bot Token (get from discord.com/developers)
DISCORD_BOT_TOKEN=

# === OPTIONAL ===

# OpenAI API Key (for image generation via gpt-image)
OPENAI_API_KEY=

# Gateway port (default: 18789)
OPENCLAW_GATEWAY_PORT=18789
